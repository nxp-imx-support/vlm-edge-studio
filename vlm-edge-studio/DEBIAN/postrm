#!/usr/bin/env bash

set -e

# ============================================================================
# Configuration Variables
# ============================================================================
readonly PACKAGE_NAME="vlm-edge-studio"
readonly SYMLINK_PATH="/usr/bin/run_vlm_edge_studio"

# ============================================================================
# Color and Icon Definitions
# ============================================================================
readonly GREEN='\033[1;32m'
readonly BLUE='\033[1;34m'
readonly NC='\033[0m'

readonly CHECK_MARK="[OK]"
readonly INFO_ICON="[i]"

# ============================================================================
# Logging Functions
# ============================================================================

print_info() {
    echo -e "${INFO_ICON}  ${BLUE}INFO:${NC} $*"
}

print_success() {
    echo -e "${CHECK_MARK} ${GREEN}SUCCESS:${NC} $*"
}

print_separator() {
    echo "─────────────────────────────────────────────────────────"
}

# ============================================================================
# Main Removal Logic
# ============================================================================

case "$1" in
    remove)
        print_separator
        print_info "Removing ${PACKAGE_NAME}..."
        print_separator
        echo ""

        # Remove symlink if it exists
        if [ -L "$SYMLINK_PATH" ]; then
            echo "Removing executable symlink: ${SYMLINK_PATH}"
            rm -f "$SYMLINK_PATH" || true
        fi

        print_info "Note: Shared resources (models, venvs, libraries) preserved"
        echo ""
        ;;

    purge)
        print_separator
        print_info "Purging ${PACKAGE_NAME}..."
        print_separator
        echo ""
        
        echo -e "${GREEN}=========================================================${NC}"
        echo -e "${GREEN} ${CHECK_MARK}  Package Purged Successfully${NC}"
        echo -e "${GREEN}=========================================================${NC}"
        echo ""
        
        print_info "Preserved shared resources:"
        echo -e "  ${GREEN}[+]${NC} Models in /usr/share/llm"
        echo -e "  ${GREEN}[+]${NC} Python virtual environments"
        echo -e "  ${GREEN}[+]${NC} Libraries from rt-sdk-ara2"
        echo ""
        ;;

    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        ;;

    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

#DEBHELPER#

exit 0